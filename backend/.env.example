APP_NAME=Medi-Help API
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://health_user:health_password@localhost:5433/medi_help
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-this-secret-in-development
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

LOCAL_STORAGE_PATH=./storage/uploads
MAX_UPLOAD_SIZE_MB=10
STORAGE_BACKEND=local
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=medi-help-documents
S3_REGION=us-east-1

OCR_BACKEND=tesseract
TESSERACT_COMMAND=
GOOGLE_VISION_API_KEY=
EXTRACTION_BACKEND=heuristic
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
